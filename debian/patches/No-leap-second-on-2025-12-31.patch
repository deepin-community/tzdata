 leap-seconds.list | 8 ++++----
 1 file changed, 4 insertions(+), 4 deletions(-)

diff --git a/leap-seconds.list b/leap-seconds.list
index 6f861c88..649a22c6 100644
--- a/leap-seconds.list
+++ b/leap-seconds.list
@@ -60,15 +60,15 @@
